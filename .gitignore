# .gitignore for ClipBrdComp Broker
# Ignore build artifacts and local files

# Build output
lib/
lib/**
clipbrd_broker

# Free Pascal / Lazarus
*.o
*.ppu
*.compiled
*.lrs
*.lazpkg
*.res
*.lpi~
*.lpr~
*.lps

# Logs and databases
broker.log
broker.db
broker.db-shm
broker.db-wal

# Backups and IDE
backup/
.vscode/
.idea/
*~
.DS_Store
# Generated build artifacts
*.o
*.ppu
*.or
# Agent/build lib directories
agent/**/lib/
broker/**/lib/
# DB and logs
broker.db*
*.log
*.pid
tools/run_logs/
debug/
# Keep official binaries in bin
!bin/
