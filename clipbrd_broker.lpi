      </Unit13>
      <Unit14>
        <Filename Value="../compat/text_convert.pas"/>
        <IsPartOfProject Value="True"/>
      </Unit14>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="clipbrd_broker"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="../protocol;../compat"/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
